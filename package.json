{
  "name": "env-struct",
  "version": "1.5.0",
  "description": "Schema-first environment variable loader with typed accessors and metadata.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run format && tsup src/index.ts --dts --format cjs --sourcemap --clean",
    "format": "prettier --write .",
    "lint": "tsc --project tsconfig.test.json",
    "test": "vitest run",
    "attw": "attw --pack ."
  },
  "keywords": [
    "env",
    "environment",
    "zod",
    "schema",
    "validation",
    "env-struct"
  ],
  "author": "Donobu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donobu-inc/env-struct.git"
  },
  "bugs": {
    "url": "https://github.com/donobu-inc/env-struct/issues"
  },
  "homepage": "https://github.com/donobu-inc/env-struct#readme",
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "prettier": "^3.3.3",
    "tsup": "^8.5.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
